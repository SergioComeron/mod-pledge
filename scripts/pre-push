#!/usr/bin/env bash
#
# pre-push hook for mod_pledge.
# - Runs code sniffer (mandatory) and PHPUnit tests before each push.
# - On push to main: auto-bumps version.php and commits it.
#
# The plugin is a standalone repo (~/moodles/plugins/mod_pledge) symlinked
# into several Moodle installs (4.5 in mod/pledge, 5.2 in public/mod/pledge),
# so the classic "../.." no longer applies.
#
# Install: bash scripts/install-hooks.sh

set -e

# Capture refs from stdin before they are consumed.
PUSH_REFS=$(cat)

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PHPCS="${PLUGIN_DIR}/vendor/bin/phpcs"

# Detect the Moodle root used to run PHPUnit.
detect_moodle_root() {
    # 1. Manual override via environment variable.
    if [ -n "${PLEDGE_MOODLE_ROOT}" ] && [ -f "${PLEDGE_MOODLE_ROOT}/vendor/bin/phpunit" ]; then
        echo "${PLEDGE_MOODLE_ROOT}"
        return 0
    fi
    # 2. Classic layout: the plugin lives inside the Moodle tree (mod/pledge).
    local classic
    classic="$(cd "${PLUGIN_DIR}/../.." 2>/dev/null && pwd)"
    if [ -n "${classic}" ] && [ -f "${classic}/vendor/bin/phpunit" ] && [ -f "${classic}/version.php" ]; then
        echo "${classic}"
        return 0
    fi
    # 3. Standalone layout: probe known candidate installs, preferring the
    # newest one with PHPUnit installed; the rest are skipped automatically.
    local candidates=(
        "${HOME}/moodles/stable_502/moodle"
        "${HOME}/moodles/stable_405/moodle"
        "${HOME}/moodles/stable_501/moodle"
        "${HOME}/moodles/stable_main/moodle"
    )
    local c
    for c in "${candidates[@]}"; do
        if [ -f "${c}/vendor/bin/phpunit" ]; then
            echo "${c}"
            return 0
        fi
    done
    return 1
}

MOODLE_ROOT="$(detect_moodle_root || true)"
PHPUNIT="${MOODLE_ROOT}/vendor/bin/phpunit"

# --- Code sniffer (mandatory) ---

if [ ! -f "${PHPCS}" ]; then
    echo "phpcs not found at ${PHPCS}"
    echo "   Run 'composer install' inside the plugin directory."
    exit 1
fi

echo "Running code sniffer..."

cd "${PLUGIN_DIR}"
if ! "${PHPCS}" --standard=phpcs.xml; then
    echo ""
    echo "Code style errors. Push cancelled."
    echo "  Run: vendor/bin/phpcbf --standard=phpcs.xml"
    exit 1
fi

echo "Code style OK."

# --- PHPUnit (skipped if there is no Moodle install with PHPUnit) ---

if [ -z "${MOODLE_ROOT}" ] || [ ! -f "${PHPUNIT}" ]; then
    echo "PHPUnit not found: no Moodle install with vendor/bin/phpunit was located."
    echo "   Skipping tests (only code style was validated)."
    echo "   To force a Moodle root: export PLEDGE_MOODLE_ROOT=/path/to/moodle"
else
    echo "Running PHPUnit tests (${MOODLE_ROOT})..."

    cd "${MOODLE_ROOT}"

    set +e
    PHPUNIT_OUTPUT=$(php "${PHPUNIT}" --testsuite mod_pledge_testsuite 2>&1)
    PHPUNIT_EXIT=$?
    set -e

    if echo "${PHPUNIT_OUTPUT}" | grep -q "initialised for different version"; then
        echo "  PHPUnit environment outdated. Reinitialising..."
        # In 5.x the code lives under public/, so init.php moves there.
        if [ -f admin/tool/phpunit/cli/init.php ]; then
            php admin/tool/phpunit/cli/init.php 2>&1 | tail -3
        elif [ -f public/admin/tool/phpunit/cli/init.php ]; then
            php public/admin/tool/phpunit/cli/init.php 2>&1 | tail -3
        fi
        echo "  Re-running tests..."
        set +e
        PHPUNIT_OUTPUT=$(php "${PHPUNIT}" --testsuite mod_pledge_testsuite 2>&1)
        PHPUNIT_EXIT=$?
        set -e
    fi

    echo "${PHPUNIT_OUTPUT}"

    if [ $PHPUNIT_EXIT -ne 0 ]; then
        echo ""
        echo "Tests failed. Push cancelled."
        exit 1
    fi

    echo "All tests pass."
fi

# --- Auto version bump on push to main ---

PUSH_TO_MAIN=false
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
        PUSH_TO_MAIN=true
    fi
done <<< "$PUSH_REFS"

if [ "$PUSH_TO_MAIN" = true ]; then
    echo ""
    echo "Push to main detected. Checking version..."

    VERSION_FILE="${PLUGIN_DIR}/version.php"

    LAST_COMMIT=$(git -C "${PLUGIN_DIR}" log -1 --pretty=format:"%s")
    if [[ "$LAST_COMMIT" == Release:\ bump\ version* ]]; then
        CURRENT_RELEASE=$(grep "\$plugin->release" "${VERSION_FILE}" | sed "s/.*'\([^']*\)'.*/\1/")
        echo "Version already bumped (${CURRENT_RELEASE}). Continuing push."
    else
        CURRENT_RELEASE=$(grep "\$plugin->release" "${VERSION_FILE}" | sed "s/.*'\([^']*\)'.*/\1/")
        CURRENT_BUILD=$(grep "\$plugin->version" "${VERSION_FILE}" | sed 's/[^0-9]*\([0-9]\{10\}\).*/\1/')

        git -C "${PLUGIN_DIR}" fetch --tags --quiet 2>/dev/null || true

        LAST_TAG=$(git -C "${PLUGIN_DIR}" describe --tags --abbrev=0 2>/dev/null || echo "")
        if [ -n "$LAST_TAG" ]; then
            COMMITS=$(git -C "${PLUGIN_DIR}" log "${LAST_TAG}..HEAD" --pretty=format:"%s" --no-merges)
        else
            COMMITS=$(git -C "${PLUGIN_DIR}" log --pretty=format:"%s" --no-merges)
        fi

        BUMP="patch"
        FEAT_RE='^[Ff]eat[:(]'
        while IFS= read -r commit_msg; do
            if [[ "$commit_msg" =~ $FEAT_RE ]]; then
                BUMP="minor"
                break
            fi
        done <<< "$COMMITS"

        IFS='.' read -ra PARTS <<< "$CURRENT_RELEASE"
        MAJOR=${PARTS[0]:-0}
        MINOR=${PARTS[1]:-0}
        PATCH=${PARTS[2]:-0}

        if [ "$BUMP" = "minor" ]; then
            MINOR=$((MINOR + 1))
            NEW_RELEASE="${MAJOR}.${MINOR}"
        else
            PATCH=$((PATCH + 1))
            NEW_RELEASE="${MAJOR}.${MINOR}.${PATCH}"
        fi

        TODAY=$(date +%Y%m%d)
        if [[ "$CURRENT_BUILD" == ${TODAY}* ]]; then
            SEQ="${CURRENT_BUILD: -2}"
            NEW_BUILD="${TODAY}$(printf '%02d' $((10#$SEQ + 1)))"
        else
            NEW_BUILD="${TODAY}00"
        fi

        echo "   Version:  ${CURRENT_RELEASE} -> ${NEW_RELEASE}  (bump: ${BUMP})"
        echo "   Build:    ${CURRENT_BUILD} -> ${NEW_BUILD}"

        python3 - "${VERSION_FILE}" "${NEW_BUILD}" "${NEW_RELEASE}" << 'PYEOF'
import sys, re

filepath, new_build, new_release = sys.argv[1], sys.argv[2], sys.argv[3]

with open(filepath, 'r') as f:
    content = f.read()

content = re.sub(r'(\$plugin->version = )\d+', rf'\g<1>{new_build}', content)
content = re.sub(r"(\$plugin->release = ')[^']+(';)", rf"\g<1>{new_release}\g<2>", content)

with open(filepath, 'w') as f:
    f.write(content)
PYEOF

        git -C "${PLUGIN_DIR}" add version.php
        git -C "${PLUGIN_DIR}" commit -m "Release: bump version to ${NEW_RELEASE}"

        echo ""
        echo "version.php bumped to ${NEW_RELEASE} and committed."
        echo "  Run again: git push origin main"
        echo ""
        exit 1
    fi
fi

echo "Continuing push."
exit 0
