<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/pledge/db" VERSION="2025050800" COMMENT="XMLDB file for mod_pledge" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../lib/xmldb/xmldb.xsd">
    <TABLES>

        <!-- Tabla principal del módulo -->
        <TABLE NAME="pledge" COMMENT="Tabla principal del módulo pledge">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="intro" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0"/>
                <FIELD NAME="linkedactivity" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timeopen" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="timeclosed" TYPE="int" LENGTH="10" NOTNULL="false" DEFAULT="0"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="course" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
        </TABLE>

        <!-- Tabla de aceptaciones por usuario -->
        <TABLE NAME="pledge_acceptance" COMMENT="Aceptación del código de honor por parte de los usuarios">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="pledgeid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timeaccepted" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <!-- Nuevo campo para el justificante, guardando el timestamp en el que se envía.
                     Se permite valor nulo para indicar que aún no se ha enviado -->
                <FIELD NAME="justificante" TYPE="int" LENGTH="10" NOTNULL="false" />
                <!-- Prueba del consentimiento del tratamiento de datos (RGPD). -->
                <FIELD NAME="consenttime" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Timestamp en el que el usuario otorgó el consentimiento del tratamiento de datos"/>
                <FIELD NAME="consentversion" TYPE="char" LENGTH="40" NOTNULL="false" COMMENT="Hash SHA-1 del texto de consentimiento aceptado, para saber qué versión otorgó"/>
                <FIELD NAME="honorversion" TYPE="char" LENGTH="40" NOTNULL="false" COMMENT="Hash SHA-1 del texto del código de honor aceptado, para saber qué versión aceptó"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="pledgefk" TYPE="foreign" FIELDS="pledgeid" REFTABLE="pledge" REFFIELDS="id"/>
                <KEY NAME="userfk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="pledge_user_idx" UNIQUE="true" FIELDS="pledgeid, userid"/>
            </INDEXES>
        </TABLE>

        <!-- Versiones de los textos aceptados (consentimiento y código de honor), indexadas por hash -->
        <TABLE NAME="pledge_textversion" COMMENT="Contenido de cada versión de texto aceptada, para poder recuperar el texto exacto">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="contenthash" TYPE="char" LENGTH="40" NOTNULL="true" COMMENT="Hash SHA-1 del contenido; enlaza con consentversion/honorversion de pledge_acceptance"/>
                <FIELD NAME="content" TYPE="text" NOTNULL="true" COMMENT="Contenido HTML del texto tal y como se mostró al usuario"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="contenthash_idx" UNIQUE="true" FIELDS="contenthash"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>
